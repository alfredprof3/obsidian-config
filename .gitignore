# 1. Ignore everything by default
*

# 2. Allow Git to scan into directories
!*/

# 3. CRITICAL: Do NOT ignore the gitignore file itself
!.gitignore

# 4. Un-ignore your required root configuration files
!app.json
!appearance.json
!community-plugins.json
!core-plugins.json
!hotkeys.json

# 5. Un-ignore required directories and all their contents
!snippets/**
!themes/**

# 6. Allow the plugins directory contents...
!plugins/**

# 7. ...BUT explicitly ignore these specific items inside plugins
plugins/remotely-save/
plugins/obsidian-git/

# 8. Explicitly ignore workspace.json
workspace.json
